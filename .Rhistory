desc_vars <- c("L", "K", "WB", "M", "GO", "own_w_share")
desc_table <- df %>%
dplyr::select(dplyr::all_of(desc_vars)) %>%
summarise(across(
everything(),
list(
N = ~sum(!is.na(.)),
Mean = ~mean(., na.rm = TRUE),
SD = ~sd(., na.rm = TRUE),
P25 = ~quantile(., 0.25, na.rm = TRUE),
Median = ~median(., na.rm = TRUE),
P75 = ~quantile(., 0.75, na.rm = TRUE),
Min = ~min(., na.rm = TRUE),
Max = ~max(., na.rm = TRUE)
),
.names = "{.col}_{.fn}"
)) %>%
tidyr::pivot_longer(
cols = everything(),
names_to = c("Variable", ".value"),
names_pattern = "^(.*)_(N|Mean|SD|P25|Median|P75|Min|Max)$"
) %>%
mutate(
Variable = dplyr::recode(
Variable,
"L" = "Employees",
"K" = "Fixed assets",
"WB" = "Wage bill",
"M" = "Materials expenditure",
"GO" = "Gross output",
"own_w_share" = "Share of Female Ownership"
)
)
kable(desc_table, digits = 2, caption = "Descriptive Statistics") %>%
kable_styling(full_width = FALSE)
pdat <- df %>% filter(!is.na(own_w_share))
dens <- density(pdat$own_w_share, bw = "nrd0")
dens_df <- data.frame(
y    = dens$x,      # the % values
dens = dens$y       # the density values
)
max_dens <- max(dens$y)   # to know the scale
# Step 2: plot
ggplot(dens_df, aes(y = y)) +
geom_ribbon(
aes(xmin = -dens, xmax = dens),
fill = "#187864", color = "#187864", alpha = 0.2
) +
geom_boxplot(
data = pdat,
aes(x = 0, y = own_w_share),
width = 0.005, fill = "white",
outlier.color = "#187864", color = "#187864", alpha = 0.8
) +
scale_y_continuous(labels = label_percent(scale = 1)) +
scale_x_continuous(
breaks = pretty(c(-max(dens_df$dens), max(dens_df$dens))),
labels = abs  # show positive values on both sides
) +
labs(
title = "Distribution of Female Ownership Share",
x = "Density",
y = "Percentage (%)"
) +
annotate("text", x = 7, y = 0.1,
label = paste0("max density at 0 = ", round(max_dens, 3)),
hjust = 0, size = 3.5, color = "#187864") +
theme_minimal(base_size = 16, base_family = "cmunsi") +
theme(
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
axis.text = element_text(color = "black"),
axis.line = element_line(color = "black")
)
