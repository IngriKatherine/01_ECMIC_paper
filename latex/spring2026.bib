@article{yeh_monopsony_2022,
	title = {Monopsony in the {US} {Labor} {Market}},
	volume = {112},
	issn = {0002-8282},
	url = {https://pubs.aeaweb.org/doi/10.1257/aer.20200025},
	doi = {10.1257/aer.20200025},
	abstract = {This paper quantifies employer market power in US manufacturing and how it has changed over time. Using administrative data, we estimate plant-level markdowns—the ratio between a plant’s marginal revenue product of labor and its wage. We find most manufacturing plants operate in a monopsonistic environment, with an average markdown of 1.53, implying a worker earning only 65 cents on the marginal dollar generated. To investigate long-term trends for the entire sector, we propose a novel, theoretically grounded measure for the aggregate markdown. We find that it decreased between the late 1970s and the early 2000s, but has been sharply increasing since. (JEL J24, J31, J38, J42, L13, L60)},
	language = {en},
	number = {7},
	urldate = {2026-02-24},
	journal = {American Economic Review},
	author = {Yeh, Chen and Macaluso, Claudia and Hershbein, Brad},
	month = jul,
	year = {2022},
	pages = {2099--2138},
}

